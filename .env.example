# GitHub OAuth App credentials
# Create an OAuth App at: https://github.com/settings/developers
#   Homepage URL:               http://localhost:3000
#   Authorization callback URL: http://localhost:3000/auth/callback
#
# NEXT_PUBLIC_GITHUB_CLIENT_ID is exposed to the browser (safe).
# GITHUB_CLIENT_SECRET is server-only — never prefix it with NEXT_PUBLIC_.
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_oauth_app_client_secret

# Base URL of the app (used to build the OAuth redirect URI)
NEXT_PUBLIC_APP_URL=http://localhost:3000
