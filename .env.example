###############################################################
#  GITHUB OAUTH APP
#  Create one at: https://github.com/settings/developers
###############################################################
#  Homepage URL:               http://localhost:3000
#  Authorization callback URL: http://localhost:3000/auth/callback
#
#  NEXT_PUBLIC_*         exposed to the browser (safe to be public)
#  GITHUB_CLIENT_SECRET  server-only — never prefix with NEXT_PUBLIC_

NEXT_PUBLIC_GITHUB_CLIENT_ID=your_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_oauth_app_client_secret


###############################################################
#  APPLICATION
###############################################################
#  Base URL used to build the OAuth redirect URI

NEXT_PUBLIC_APP_URL=http://localhost:3000
