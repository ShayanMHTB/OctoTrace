###############################################################
#  DEPENDENCIES
###############################################################
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

###############################################################
#  LOCK FILES
#  pnpm-lock.yaml is the source of truth — ignore the others
###############################################################
package-lock.json
yarn.lock

###############################################################
#  NEXT.JS / BUILD
###############################################################
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

###############################################################
#  TESTING
###############################################################
/coverage

###############################################################
#  ENVIRONMENT
#  ignore every .env*, but keep the committed example
###############################################################
.env*
!.env.example

###############################################################
#  DEBUG LOGS
###############################################################
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

###############################################################
#  AI / ASSISTANT
#  local tooling only — CLAUDE.md stays tracked
###############################################################
.claude/

###############################################################
#  DEPLOY
###############################################################
.vercel

###############################################################
#  OS / EDITOR
###############################################################
.DS_Store
*.pem
